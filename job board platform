import 'package:flutter/material.dart';
import '../services/api_service.dart';

class EmployerStatusScreen extends StatefulWidget {
  @override
  _EmployerStatusScreenState createState() => _EmployerStatusScreenState();
}

class _EmployerStatusScreenState extends State<EmployerStatusScreen> {
  String status = "Loading...";

  @override
  void initState() {
    super.initState();
    loadStatus();
  }

  void loadStatus() async {
    final result = await ApiService.getEmployerRequestStatus();
    setState(() {
      status = result;
    });
  }

  Color getColor() {
    if (status == "Pending") return Colors.orange;
    if (status == "Approved") return Colors.green;
    if (status == "Rejected") return Colors.red;
    return Colors.grey;
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text("Employer Request Status")),
      body: Center(
        child: Container(
          padding: EdgeInsets.all(30),
          decoration: BoxDecoration(
            color: getColor(),
            borderRadius: BorderRadius.circular(20),
          ),
          child: Text(
            status,
            style: TextStyle(fontSize: 22, color: Colors.white),
          ),
        ),
      ),
    );
  }
}

