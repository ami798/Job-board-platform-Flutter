      appBar: AppBar(title: Text("Apply for Job")),
      body: Padding(
        padding: EdgeInsets.all(16),
        child: Column(
          children: [
            TextField(
              controller: cvController,
              decoration: InputDecoration(labelText: "CV Link"),
            ),
            SizedBox(height: 20),
            ElevatedButton(onPressed: apply, child: Text("Submit Application"))
          ],
        ),
      ),
    );
  }
}

